---
{{ $envValueDir := print (regexReplaceAll "/releases/[^/]+$" (env "PWD") "") "/environments" }}

environments:
  ithalab:
    kubeContext: kind-ithalab-cluster
    values:
      - "{{ $envValueDir }}/ithalab.yaml"
  local:
    kubeContext: kind-kind
    values:
      - "{{ $envValueDir }}/local.yaml"
